{
  "name": "archscope-desktop",
  "version": "0.2.0-alpha",
  "private": true,
  "description": "ArchScope Electron desktop shell — wraps the shared React frontend with native IPC.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n fe,el \"npm --prefix ../frontend run dev\" \"npm run electron:dev\"",
    "electron:dev": "tsc -p tsconfig.electron.json && electron .",
    "build": "npm --prefix ../frontend run build && tsc -p tsconfig.electron.json && electron-builder",
    "build:dir": "npm --prefix ../frontend run build && tsc -p tsconfig.electron.json && electron-builder --dir",
    "lint": "tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.3"
  },
  "build": {
    "appId": "com.archscope.desktop",
    "productName": "ArchScope",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "tar.gz"],
      "category": "Development"
    }
  }
}
