<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="probe"
        Arguments=""
        InstallLocation="C:\Program Files\ArchScope\Probe">
    </Installer>
    <PackageInformation
        PackageName="Probe"
        PackageDisplayName="Probe"
        PublisherName="CN=ArchScope"
        PublisherDisplayName="ArchScope"
        Version="0.1.0.0"
        PackageDescription="A probe application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.archscope.probe"
                Description="A probe application"
                DisplayName="Probe"
                ExecutableName="probe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Probe</DisplayName>
            <PublisherDisplayName>ArchScope</PublisherDisplayName>
            <Description>A probe application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="probe.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
