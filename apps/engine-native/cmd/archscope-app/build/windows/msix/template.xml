<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="archscope"
        Arguments=""
        InstallLocation="C:\Program Files\ArchScope\ArchScope">
    </Installer>
    <PackageInformation
        PackageName="ArchScope"
        PackageDisplayName="ArchScope"
        PublisherName="CN=ArchScope"
        PublisherDisplayName="ArchScope"
        Version="0.3.4.0"
        PackageDescription="Local-first architecture diagnostics desktop">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.archscope.app"
                Description="Local-first architecture diagnostics desktop"
                DisplayName="ArchScope"
                ExecutableName="archscope"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>ArchScope</DisplayName>
            <PublisherDisplayName>ArchScope</PublisherDisplayName>
            <Description>Local-first architecture diagnostics desktop</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="archscope.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
