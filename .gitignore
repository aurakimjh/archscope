# Dependencies
node_modules/
.venv/
.venv-build/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
test-results/

# Build output
dist/
dist-electron/
build/
release/
out/
demo-site-report-bundles/
# Wails v3 keeps its template config under build/ — treat that subtree as source.
!apps/profiler-native/cmd/archscope-profiler-app/build/
!apps/profiler-native/cmd/archscope-profiler-app/build/**

# T-208: archscope wheel ships the React bundle as package data; the build
# script populates this directory at wheel-build time. The .gitkeep stays
# tracked, but the React build artifacts that the script copies in are
# generated and must not be committed.
engines/python/archscope_engine/web/static/*
!engines/python/archscope_engine/web/static/.gitkeep

# Local environment
.env
.env.local
.DS_Store

# Local test data (large log files, not committed)
test-data/

# Local AI agent instructions
CLAUDE.MD
CLAUDE.md
GEMINI.MD
GEMINI.md
AGENTS.MD
AGENTS.md
CODEX.MD
CODEX.md

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Keep curated sample/test log files
!examples/**/*.log

# Generated sample outputs are useful during development, but keep placeholders.
examples/outputs/*.tmp.json
